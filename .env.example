# Powers the auto "Live Apps" section (src/components/sections/LiveApps.astro).
# Read at BUILD time only — never shipped to the browser.
# Copy this file to `.env` (which is gitignored) and fill in the values.

# Vercel personal access token with read access to your projects.
# Create at: Vercel → Account Settings → Tokens.
VERCEL_TOKEN=

# Only needed if your projects live under a Vercel TEAM (not a personal account).
# Find it at: Vercel → Team Settings → General → Team ID.
VERCEL_TEAM_ID=
